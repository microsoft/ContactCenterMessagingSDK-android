<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="Home"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnOpenChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Open Chat" />

    <!--
        This TextView shows a new-message indicator when the user is on this screen
        and a message arrives from the agent. In a real app this could be a badge,
        a notification, or any highlight UI. Here it simply displays the last log line.
    -->
    <TextView
        android:id="@+id/tvMessageLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="@android:color/holo_blue_dark"
        android:text="" />

</LinearLayout>
