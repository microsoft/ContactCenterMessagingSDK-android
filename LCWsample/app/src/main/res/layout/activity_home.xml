<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- HERO HEADER                                            -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/lcw_messagingColorPrimary"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/blue_circular"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_chat_icon"
                    android:tint="@android:color/white"
                    android:contentDescription="LCW logo" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="LCW Chat Monitor"
                android:textColor="@android:color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="0.01" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Real-time SDK event dashboard"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@color/lcw_messagingGradientStart" />

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- BODY                                                   -->
        <!-- ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Quick-Access Card ─────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUICK ACCESS"
                        android:textColor="@color/lcw_messagingColorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="14dp" />

                    <Button
                        android:id="@+id/btnOpenChat"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_home_button"
                        android:text="Open Chat Configuration"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Set up org credentials and launch the chat widget"
                        android:textColor="@color/lcw_colorPreChatTextSubtitle"
                        android:textSize="12sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Live Events Card ──────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <View
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            android:background="@drawable/bg_status_dot"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Live Events"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/lcw_txt_color_black" />

                        <Button
                            android:id="@+id/btnClearLog"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/transparent"
                            android:text="Clear All"
                            android:textColor="@color/lcw_messagingColorPrimary"
                            android:textSize="13sp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:stateListAnimator="@null" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EBEBEB" />

                    <!-- ── newMessage ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_event_label"
                            android:text="newMessage"
                            android:textColor="@color/lcw_messagingColorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/tvNewMessage"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="—"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="13sp"
                            android:ellipsize="end"
                            android:maxLines="2" />

                        <Button
                            android:id="@+id/btnClearNewMessage"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@color/transparent"
                            android:text="×"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="18sp"
                            android:padding="0dp"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F2" android:layout_marginStart="16dp" />

                    <!-- ── agentAssigned ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_event_label"
                            android:text="agentAssigned"
                            android:textColor="@color/lcw_messagingColorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/tvAgentAssigned"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="—"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="13sp"
                            android:ellipsize="end"
                            android:maxLines="1" />

                        <Button
                            android:id="@+id/btnClearAgentAssigned"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@color/transparent"
                            android:text="×"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="18sp"
                            android:padding="0dp"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F2" android:layout_marginStart="16dp" />

                    <!-- ── chatInitiated ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_event_label"
                            android:text="chatInitiated"
                            android:textColor="@color/lcw_messagingColorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/tvChatInitiated"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="—"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btnClearChatInitiated"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@color/transparent"
                            android:text="×"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="18sp"
                            android:padding="0dp"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F2" android:layout_marginStart="16dp" />

                    <!-- ── chatEnded ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_event_label"
                            android:text="chatEnded"
                            android:textColor="@color/lcw_messagingColorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/tvChatEnded"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="—"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btnClearChatEnded"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@color/transparent"
                            android:text="×"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="18sp"
                            android:padding="0dp"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F2" android:layout_marginStart="16dp" />

                    <!-- ── chatRestored ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_event_label"
                            android:text="chatRestored"
                            android:textColor="@color/lcw_messagingColorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/tvChatRestored"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="—"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btnClearChatRestored"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@color/transparent"
                            android:text="×"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="18sp"
                            android:padding="0dp"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F2" android:layout_marginStart="16dp" />

                    <!-- ── minimized ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_event_label"
                            android:text="minimized"
                            android:textColor="@color/lcw_messagingColorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/tvMinimized"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="—"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btnClearMinimized"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@color/transparent"
                            android:text="×"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="18sp"
                            android:padding="0dp"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F2" android:layout_marginStart="16dp" />

                    <!-- ── closed ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_event_label"
                            android:text="closed"
                            android:textColor="@color/lcw_messagingColorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/tvClosed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="—"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btnClearClosed"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@color/transparent"
                            android:text="×"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="18sp"
                            android:padding="0dp"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F2" android:layout_marginStart="16dp" />

                    <!-- ── botSignIn ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_event_label"
                            android:text="botSignIn"
                            android:textColor="@color/lcw_messagingColorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/tvBotSignIn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="—"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="13sp"
                            android:ellipsize="end"
                            android:maxLines="1" />

                        <Button
                            android:id="@+id/btnClearBotSignIn"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@color/transparent"
                            android:text="×"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="18sp"
                            android:padding="0dp"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F2" android:layout_marginStart="16dp" />

                    <!-- ── error ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_event_label"
                            android:text="error"
                            android:textColor="@color/lcw_messagingColorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/tvError"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="—"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="13sp"
                            android:ellipsize="end"
                            android:maxLines="2" />

                        <Button
                            android:id="@+id/btnClearError"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@color/transparent"
                            android:text="×"
                            android:textColor="@color/lcw_colorPreChatTextSubtitle"
                            android:textSize="18sp"
                            android:padding="0dp"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
